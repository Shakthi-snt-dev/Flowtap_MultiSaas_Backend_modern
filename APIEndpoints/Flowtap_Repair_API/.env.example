# Flowtap Flowtap_Repair_API — environment variables
# Copy to .env before running the container

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=flowtap_repair;Username=postgres;Password=your_password
RedisSettings__ConnectionString=localhost:6379
RedisSettings__InstanceName=flowtap-repair:
JwtSettings__SecretKey=change-this-to-minimum-32-char-secret
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=465
EmailSettings__Username=your@email.com
EmailSettings__Password=your-app-password
EmailSettings__FromEmail=noreply@flowtap.io
EmailSettings__FromName=Flowtap
ASPNETCORE_ENVIRONMENT=Production
